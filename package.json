{
  "name": "@forge/ds",
  "version": "1.5.0",
  "description": "Forge Design System — biblioteca de componentes, tokens e guidelines do app Forge.",
  "private": true,
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./styles.css": "./styles.css",
    "./tokens/*": "./tokens/*"
  },
  "sideEffects": ["*.css"],
  "scripts": {
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:index": "node scripts/build-index.mjs",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build": "npm run build:tokens && npm run build:index && npm run build:bundle",
    "check:drift": "node scripts/check-drift.mjs",
    "check:adherence": "node scripts/check-adherence.mjs",
    "test:render": "node scripts/render-test.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
