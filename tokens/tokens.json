      "panel": { "$value": "#121215", "$description": "shipped — surface.panel (near-black, matiz quase-neutra; entre 900 e 950 em luminância)." }
    },
    "gray": {
      "$type": "color",
      "$description": "Neutro quase-puro (faint cool): TEXTO do tema dark (único). Anchors shipped preservam a cor exata do texto embarcado (inclui half-step 450).",
