        "input": { "$value": "10px", "$extensions": { "com.forge.cssVar": "--forge-radius-input" } },
        "button": { "$value": "11px", "$extensions": { "com.forge.cssVar": "--forge-radius-button" } },
        "chip": { "$value": "8px", "$extensions": { "com.forge.cssVar": "--forge-radius-chip" } },
        "pill": { "$value": "999px", "$extensions": { "com.forge.cssVar": "--forge-radius-pill" } },
        "video": { "$value": "12px", "$description": "Moldura de vídeo — antes hardcoded.", "$extensions": { "com.forge.cssVar": "--forge-radius-video" } }
      },
      "control": {
        "$description": "Alturas de controle (OP-082).",
        "sm": { "$value": "36px", "$extensions": { "com.forge.cssVar": "--forge-size-control-sm" } },
        "md": { "$value": "44px", "$extensions": { "com.forge.cssVar": "--forge-size-control-md" } },
        "lg": { "$value": "46px", "$extensions": { "com.forge.cssVar": "--forge-size-control-lg" } }
      },
      "icon": {
        "sm": { "$value": "16px", "$extensions": { "com.forge.cssVar": "--forge-icon-sm" } },
