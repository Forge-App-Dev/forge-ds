      "on-light": { "$value": "{graphite.950}", "$description": "Texto ESCURO para uso sobre um preenchimento CLARO (ex.: fills âmbar/verde). É a cor do texto sobre o fill, não um tema — escolhida por onColor() quando o fill é claro (OP-015).", "$extensions": { "com.forge.cssVar": "--forge-on-light" } },
      "on-dark": { "$value": "{color.white}", "$description": "Saída de onColor() sobre fundo escuro (OP-011/015).", "$extensions": { "com.forge.cssVar": "--forge-on-dark" } }
