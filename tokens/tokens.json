        "3": { "$value": "6px", "$extensions": { "com.forge.cssVar": "--forge-space-3" } },
        "4": { "$value": "8px", "$extensions": { "com.forge.cssVar": "--forge-space-4" } },
        "5": { "$value": "10px", "$extensions": { "com.forge.cssVar": "--forge-space-5" } },
        "6": { "$value": "12px", "$extensions": { "com.forge.cssVar": "--forge-space-6" } },
