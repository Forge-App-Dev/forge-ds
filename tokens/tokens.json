      "100": { "$value": "#DDE3ED" },
      "200": { "$value": "#BCC6D8" },
      "300": { "$value": "#94A2BC" },
      "400": { "$value": "#6C7C9A" },
      "500": { "$value": "#4C5B77" },
      "600": { "$value": "#3A475E" },
      "700": { "$value": "#2E3A4D", "$description": "shipped — border.input (dark)." },
      "800": { "$value": "#2A3344", "$description": "shipped — border.default (dark)." },
      "850": { "$value": "#1B2536", "$description": "shipped — surface.raised, border.divider (dark)." },
      "900": { "$value": "#161E2E", "$description": "shipped — surface.default (dark)." },
