      "warning": { "$value": "{color.amber.500}", "$description": "Âmbar de aviso. Usar como fill/ícone; contraste modesto como texto pequeno (ADR-0050).", "$extensions": { "com.forge.cssVar": "--forge-warning" } },
      "danger": { "$value": "{color.coral.400}", "$description": "Destrutivo como TEXTO/borda (passa sobre superfície escura). Distinto de 'negative'.", "$extensions": { "com.forge.cssVar": "--forge-danger" } },
      "danger-fill": { "$value": "{color.coral.600}", "$description": "Preenchimento de danger COM texto (Button danger, ConfirmButton armado). Coral fechado p/ o branco passar AA — ADR-0081.", "$extensions": { "com.forge.cssVar": "--forge-danger-fill" } },
