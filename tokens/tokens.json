        "screen-h": { "$value": "{dimension.space.10}", "$description": "20 — padding horizontal de tela.", "$extensions": { "com.forge.cssVar": "--forge-space-screen-h" } },
        "card": { "$value": "{dimension.space.8}", "$description": "16 — padding interno de card.", "$extensions": { "com.forge.cssVar": "--forge-space-card" } },
        "gap": { "$value": "{dimension.space.5}", "$description": "10 — gap de lista.", "$extensions": { "com.forge.cssVar": "--forge-space-gap" } },
