      "linear": { "$value": "linear", "$description": "Rotação constante. Keyword CSS emitida verbatim.", "$extensions": { "com.forge.cssVar": "--forge-ease-linear" } },
      "emphasized": { "$value": [0.2, 0, 0, 1], "$description": "Entrada de overlay. Serializado para cubic-bezier(...).", "$extensions": { "com.forge.cssVar": "--forge-ease-emphasized" } }
    },
