      "100": { "$value": "#D8D8DC" },
      "200": { "$value": "#BFBFC5" },
      "300": { "$value": "#A8A8AF" },
      "400": { "$value": "#9a9aa2", "$description": "shipped — text.secondary." },
      "450": { "$value": "#9898A0", "$description": "shipped — text.tertiary." },
      "500": { "$value": "#8C8C94", "$description": "shipped — text.quaternary." },
      "600": { "$value": "#6C6C74", "$description": "shipped — text.disabled (decorativo, ~3:1)." },
      "800": { "$value": "#3A3B40" },
      "950": { "$value": "#0E0F12" }
