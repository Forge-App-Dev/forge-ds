        "600": { "$value": "#DC2626", "$description": "Vermelho mais fechado. Preenchimento de controles com texto branco (accent-fill): branco passa 4,5:1 (ADR-0081)." }
      },
      "coral": {
        "400": { "$value": "#e36a5a", "$description": "Coral quente. feedback.danger e tendência negativa como TEXTO (passa sobre superfície escura)." },
        "600": { "$value": "#c94b3b", "$description": "Coral fechado. Preenchimento de danger com texto branco (danger-fill): branco passa 4,5:1 (ADR-0081)." }
      },
      "emerald": {
        "400": { "$value": "#34D399" },
        "500": { "$value": "#10B981", "$description": "Verde Forge. success e accent do módulo de nutrição (Fuel)." }
      },
      "amber": {
        "400": { "$value": "#FBBF24" },
        "500": { "$value": "#F59E0B", "$description": "Âmbar. feedback.warning e categoria 5." }
      },
      "blue": { "600": { "$value": "#2563EB" } },
      "violet": { "400": { "$value": "#A78BFA" }, "500": { "$value": "#8B5CF6" } },
      "pink": { "400": { "$value": "#F472B6" }, "500": { "$value": "#EC4899" } },
      "sky": { "400": { "$value": "#38BDF8" } },
      "orange": { "400": { "$value": "#FB923C" } },
      "lime": { "500": { "$value": "#84CC16" } },
      "cyan": { "400": { "$value": "#22D3EE" } },
      "indigo": { "400": { "$value": "#818CF8" } },
      "white": { "$value": "#FFFFFF" },
