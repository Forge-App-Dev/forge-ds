        "lg": { "$value": "24px", "$extensions": { "com.forge.cssVar": "--forge-icon-lg" } },
        "xl": { "$value": "30px", "$extensions": { "com.forge.cssVar": "--forge-icon-xl" } }
      },
      "border-w": {
        "default": { "$value": "1px", "$extensions": { "com.forge.cssVar": "--forge-border-w" } },
        "strong": { "$value": "1.5px", "$extensions": { "com.forge.cssVar": "--forge-border-w-strong" } }
      },
      "focus": {
        "ring-w": { "$value": "2px", "$extensions": { "com.forge.cssVar": "--forge-focus-ring-w" } },
        "ring-offset": { "$value": "2px", "$extensions": { "com.forge.cssVar": "--forge-focus-ring-offset" } }
      },
